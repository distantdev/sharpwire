<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Sharpwire.ViewModels"
             xmlns:views="using:Sharpwire.Views"
             x:Class="Sharpwire.Views.AgentEditorView"
             x:DataType="vm:AgentEditorViewModel">
    <Panel Margin="20">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="15">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Button Grid.Column="0"
                            Content="CLOSE TAB"
                            Command="{Binding CloseAgentTabCommand}"
                            Padding="12,6" />
                    <Button Grid.Column="2"
                            Content="DUPLICATE AGENT"
                            Command="{Binding DuplicateAgentCommand}"
                            IsVisible="{Binding IsBuiltIn}"
                            Padding="12,6"
                            Background="#1a3a6e"
                            Foreground="#e8f0ff"
                            BorderBrush="#3d6eb8"
                            BorderThickness="1" />
                </Grid>

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="Model output (this session):"
                               FontSize="11"
                               Foreground="#888"
                               VerticalAlignment="Center" />
                    <Button Content="Open session log…"
                            Command="{Binding OpenSessionLogCommand}"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#7EB8D4"
                            Padding="4,2"
                            FontSize="11"
                            HorizontalAlignment="Left" />
                </StackPanel>

                <!-- Metadata Section -->
                <Border BorderBrush="#333" BorderThickness="1" Padding="15" CornerRadius="4">
                    <StackPanel Spacing="10">
                        <TextBlock Text="BASIC INFORMATION" FontWeight="Bold" FontSize="12" Foreground="#666"/>
                        <Grid ColumnDefinitions="*,*">
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Name" FontSize="11" Foreground="#888" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding Name}"
                                         IsReadOnly="{Binding !IsMetadataEditable}"
                                         Opacity="{Binding IsMetadataEditable, Converter={x:Static vm:OpacityConverter.Instance}}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Role Title" FontSize="11" Foreground="#888" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding Role}" 
                                         IsReadOnly="{Binding !IsMetadataEditable}" 
                                         Opacity="{Binding IsMetadataEditable, Converter={x:Static vm:OpacityConverter.Instance}}"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="Description" FontSize="11" Foreground="#888" Margin="0,5,0,0"/>
                        <TextBox Text="{Binding Description}" 
                                 IsReadOnly="{Binding !IsMetadataEditable}" 
                                 Opacity="{Binding IsMetadataEditable, Converter={x:Static vm:OpacityConverter.Instance}}"/>

                        <Rectangle Height="1" Fill="#333" Margin="0,10"/>
                        <TextBlock Text="LLM CONFIGURATION (OVERRIDE)" FontWeight="Bold" FontSize="12" Foreground="#666"/>
                        <TextBlock Text="Leave empty to use global system defaults." FontSize="10" Foreground="#888" Margin="0,-5,0,5"/>

                        <Grid ColumnDefinitions="*,*">
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Provider" FontSize="11" Foreground="#888" Margin="0,0,0,5"/>
                                <ComboBox SelectedItem="{Binding LlmProvider}" ItemsSource="{Binding LlmProviders}" IsEnabled="{Binding IsEditable}" HorizontalAlignment="Stretch" />
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Model ID" FontSize="11" Foreground="#888" Margin="0,0,0,5"/>
                                
                                <Panel>
                                    <ComboBox SelectedItem="{Binding ModelId}" ItemsSource="{Binding GeminiModels}" 
                                              IsVisible="{Binding LlmProvider, Converter={StaticResource StringEqualsConverter}, ConverterParameter='Gemini'}"
                                              IsEnabled="{Binding IsEditable}" HorizontalAlignment="Stretch" IsEditable="True"/>
                                    
                                    <ComboBox SelectedItem="{Binding ModelId}" ItemsSource="{Binding OpenAiModels}" 
                                              IsVisible="{Binding LlmProvider, Converter={StaticResource StringEqualsConverter}, ConverterParameter='OpenAI'}"
                                              IsEnabled="{Binding IsEditable}" HorizontalAlignment="Stretch" IsEditable="True"/>

                                    <ComboBox SelectedItem="{Binding ModelId}" ItemsSource="{Binding ClaudeModels}" 
                                              IsVisible="{Binding LlmProvider, Converter={StaticResource StringEqualsConverter}, ConverterParameter='Anthropic'}"
                                              IsEnabled="{Binding IsEditable}" HorizontalAlignment="Stretch" IsEditable="True"/>

                                    <TextBox Text="{Binding ModelId}" Watermark="e.g. llama3"
                                             IsVisible="{Binding LlmProvider, Converter={StaticResource StringEqualsConverter}, ConverterParameter='Custom'}"
                                             IsEnabled="{Binding IsEditable}" HorizontalAlignment="Stretch"/>

                                    <TextBox Text="{Binding ModelId}" Watermark="Global default"
                                             IsVisible="{Binding LlmProvider, Converter={StaticResource StringEqualsConverter}, ConverterParameter=''}"
                                             IsEnabled="{Binding IsEditable}" HorizontalAlignment="Stretch"/>
                                </Panel>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Chat &amp; graph color" FontSize="11" Foreground="#888" Margin="0,10,0,0"/>
                        <views:AccentSwatchPicker HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>

                <!-- Instructions Section -->
                <Border BorderBrush="#333" BorderThickness="1" Padding="15" CornerRadius="4">
                    <StackPanel Spacing="10" Opacity="{Binding IsEditable, Converter={x:Static vm:OpacityConverter.Instance}, FallbackValue=0.6}">
                        <TextBlock Text="SYSTEM PROMPT (BRAIN)" FontWeight="Bold" FontSize="12" Foreground="#666"/>
                        <TextBox Text="{Binding Instructions}" 
                                 IsReadOnly="{Binding !IsEditable}"
                                 AcceptsReturn="True" 
                                 Height="250" 
                                 TextWrapping="Wrap" 
                                 FontFamily="Cascadia Code, Consolas, Monospace"/>
                    </StackPanel>
                </Border>

                <!-- Tools and Handoff Section -->
                <Grid ColumnDefinitions="*,*" VerticalAlignment="Stretch" Opacity="{Binding IsEditable, Converter={x:Static vm:OpacityConverter.Instance}, FallbackValue=0.6}">
                    <Border Grid.Column="0" BorderBrush="#333" BorderThickness="1" Padding="15" CornerRadius="4" Margin="0,0,10,0">
                        <StackPanel Spacing="10">
                            <TextBlock Text="ENABLED TOOLS" FontWeight="Bold" FontSize="12" Foreground="#666"/>
                            <ScrollViewer MinHeight="100" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Tools}" IsEnabled="{Binding IsEditable}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ToolOptionViewModel">
                                            <CheckBox IsChecked="{Binding IsEnabled}" Content="{Binding Id}" Margin="0,2"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" BorderBrush="#333" BorderThickness="1" Padding="15" CornerRadius="4">
                        <StackPanel Spacing="10">
                            <TextBlock Text="JSON RESPONSE SCHEMA" FontWeight="Bold" FontSize="12" Foreground="#666"/>
                            <TextBlock Text="Constrain output to valid JSON (Gemini ResponseFormat)" FontSize="11" Foreground="#888" TextWrapping="Wrap"/>
                            <TextBox Text="{Binding JsonSchema}"
                                     Watermark="e.g. { 'type': 'object', 'properties': { 'status': { 'type': 'string' } } }"
                                     AcceptsReturn="True"
                                     Height="100"
                                     IsEnabled="{Binding IsEditable}"
                                     FontFamily="Cascadia Code,Consolas,Monospace"
                                     FontSize="12"/>

                            <Rectangle Height="1" Fill="#333" Margin="0,10"/>

                            <TextBlock Text="NEXT HANDOFF" FontWeight="Bold" FontSize="12" Foreground="#666"/>
                            <TextBlock Text="Who should work next?" FontSize="11" Foreground="#888"/>
                            <ComboBox ItemsSource="{Binding AvailableAgents}"
                                      SelectedItem="{Binding NextAgentName}"
                                      IsEnabled="{Binding IsEditable}"
                                      HorizontalAlignment="Stretch"/>

                            <Rectangle Height="1" Fill="#333" Margin="0,10"/>

                            <TextBlock Text="ORCHESTRATOR VISIBILITY" FontWeight="Bold" FontSize="12" Foreground="#666"/>
                            <TextBlock Text="Register chain as a Tool" FontSize="11" Foreground="#888" TextWrapping="Wrap"/>
                            <ToggleSwitch IsChecked="{Binding IsChainEntry}"
                                          IsEnabled="{Binding IsEditable}"
                                          OnContent="Visible to Orchestrator"
                                          OffContent="Hidden"
                                          Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>                </Grid>

                <Button Content="DELETE AGENT"
                        Command="{Binding DeleteAgentCommand}"
                        IsVisible="{Binding CanDeleteAgent}"
                        HorizontalAlignment="Left"
                        Margin="0,4,0,0"
                        Padding="16,8"
                        Background="#6b1c1c"
                        Foreground="#ffe0e0"
                        BorderBrush="#a03535"
                        BorderThickness="1" />
            </StackPanel>
        </ScrollViewer>
    </Panel>
</UserControl>

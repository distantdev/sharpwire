<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Sharpwire.ViewModels"
             x:Class="Sharpwire.Views.AgentLogView"
             x:DataType="vm:AgentLogViewModel">
    <DockPanel Margin="16">
        <Border DockPanel.Dock="Top"
                BorderBrush="#333"
                BorderThickness="0,0,0,1"
                Padding="0,0,0,12"
                Margin="0,0,0,12">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="SESSION LOG"
                               FontWeight="Bold"
                               FontSize="12"
                               Foreground="#888"
                               LetterSpacing="1" />
                    <TextBlock Text="{Binding AgentKey}"
                               FontSize="11"
                               Foreground="#666" />
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="Receiving…"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#5AC8FA"
                           VerticalAlignment="Center"
                           Margin="12,0"
                           IsVisible="{Binding Monitor.IsReceivingStream}" />
                <Button Grid.Column="2"
                        Content="CLEAR LOG"
                        Command="{Binding Monitor.ClearOutputCommand}"
                        Padding="12,6"
                        FontSize="11"
                        VerticalAlignment="Center" />
            </Grid>
        </Border>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto">
            <SelectableTextBlock Text="{Binding Monitor.SessionLog}"
                                 TextWrapping="Wrap"
                                 FontFamily="Cascadia Code, Consolas, Monospace"
                                 FontSize="12"
                                 Foreground="#E0E6ED" />
        </ScrollViewer>
    </DockPanel>
</UserControl>
